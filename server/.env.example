# Local default
PORT=8787

# Persist API data to this directory (use /data on Railway with a mounted volume)
DATA_DIR=./server/data

# CORS allowlist for browser clients
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,https://derpydonut.com,https://www.derpydonut.com

# Cookie settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
